import tkinter as tk
from tkinter import filedialog, messagebox
import os, hashlib



def xor_logic(data, password):
    # Превращаем пароль в 32-байтный ключ
    key = hashlib.sha256(password.encode('utf-8')).digest()
    return bytearray(b ^ key[i % len(key)] for i, b in enumerate(data))



def pick_file():
    path = filedialog.askopenfilename()
    if path:
        entry_path.delete(0, tk.END)
        entry_path.insert(0, str(path))



def run_action(mode):
    path = entry_path.get().strip()
    passw = entry_key.get().strip()

    if not path or not os.path.exists(path) or not passw:
        return messagebox.showerror("Ошибка", "Выбери файл и введи пароль!")

    try:
        with open(path, "rb") as f:
            data = f.read()


        result = xor_logic(data, passw)

        if mode == "enc":

            out_path = path + ".safe"
            msg = "Зашифровано!"
        else:

            if path.endswith(".safe"):
                out_path = path.replace(".safe", "_RECOVERED.png")
            else:
                out_path = "RESULT_SCREENSHOT.png"
            msg = "Расшифровано!"

        with open(out_path, "wb") as f:
            f.write(result)
            f.flush()
            os.fsync(f.fileno())

        messagebox.showinfo("Успех", f"{msg}\nФайл: {os.path.basename(out_path)}")

        if mode == "dec":

            os.startfile(os.path.abspath(out_path))

    except Exception as e:
        messagebox.showerror("Ошибка", f"Ошибка: {e}")



root = tk.Tk()
root.title("PNG Crypt v28")
root.geometry("400x250")

tk.Label(root, text="1. Выбери скриншот (.png):").pack(pady=5)
entry_path = tk.Entry(root, width=45);
entry_path.pack()
tk.Button(root, text="ОБЗОР", command=pick_file).pack(pady=5)

tk.Label(root, text="2. Пароль:").pack(pady=5)
entry_key = tk.Entry(root, width=45);
entry_key.pack()

f = tk.Frame(root);
f.pack(pady=20)
tk.Button(f, text="ЗАШИФРОВАТЬ", bg="#ff4d4d", fg="white", width=15, command=lambda: run_action("enc")).pack(
    side="left", padx=10)
tk.Button(f, text="РАСШИФРОВАТЬ", bg="#2eb82e", fg="white", width=15, command=lambda: run_action("dec")).pack(
    side="left")

root.mainloop()

