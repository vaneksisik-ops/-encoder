import tkinter as tk
from tkinter import filedialog, messagebox
import os, hashlib

FOLDER = "SAVEPIC"
if not os.path.exists(FOLDER):
    os.makedirs(FOLDER)

def xor_logic(data, psw):
    secret_key = hashlib.sha256(psw.encode('utf-8')).digest()
    return bytearray(b ^ secret_key[i % len(secret_key)] for i, b in enumerate(data))

def get_file():
    path = filedialog.askopenfilename()
    if path:
        path_input.delete(0, tk.END)
        path_input.insert(0, str(path))

def start_action(mode):
    file_path = path_input.get().strip()
    user_key = key_input.get().strip()

    if not file_path or not os.path.exists(file_path):
        return messagebox.showerror("Ошибка", "Файл не выбран!")
    if not user_key:
        return messagebox.showerror("Ошибка", "Введите пароль!")

    try:
        with open(file_path, "rb") as f:
            all_bytes = f.read()

        result = xor_logic(all_bytes, user_key)
        file_name = os.path.basename(file_path)

        if mode == "enc":
            new_path = os.path.join(FOLDER, file_name + ".locked")
            with open(new_path, "wb") as f:
                f.write(result)
            try:
                os.remove(file_path)
                msg = "Готово! Файл зашифрован."
            except:
                msg = "Зашифровано, но оригинал остался."
            path_input.delete(0, tk.END)
            path_input.insert(0, os.path.abspath(new_path))
            messagebox.showinfo("Успех", msg)
        else:
            clean_name = "READY_" + file_name.replace(".locked", "")
            if "." not in clean_name: clean_name += ".png"
            final_path = os.path.join(FOLDER, clean_name)
            with open(final_path, "wb") as f:
                f.write(result)
            os.startfile(os.path.abspath(final_path))
            messagebox.showinfo("Успех", "Файл открыт!")
    except Exception as err:
        messagebox.showerror("Ошибка", "Что-то пошло не так")

win = tk.Tk()
win.title("SafePic")
win.geometry("450x280")

tk.Label(win, text="ВНИМАНИЕ: Оригинал будет удален!", fg="red", font='Arial 9 bold').pack(pady=10)
tk.Label(win, text="1. Выберите файл:").pack()
path_input = tk.Entry(win, width=50); path_input.pack(pady=2)
tk.Button(win, text="ОБЗОР", command=get_file).pack(pady=5)
tk.Label(win, text="2. Пароль:", font='Arial 10 bold').pack()
key_input = tk.Entry(win, width=50, show="*"); key_input.pack(pady=2)
tk.Label(win, text=f"Папка: {FOLDER}", fg="gray").pack(pady=10)

bottom = tk.Frame(win); bottom.pack(pady=10)
tk.Button(bottom, text="ЗАШИФРОВАТЬ", bg="#d9534f", fg="white", width=15, height=2, command=lambda: start_action("enc")).pack(side="left", padx=10)
tk.Button(bottom, text="РАСШИФРОВАТЬ", bg="#5cb82e", fg="white", width=15, height=2, command=lambda: start_action("dec")).pack(side="left")

win.mainloop()
